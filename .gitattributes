* text=auto

# Keep source and config files in LF across platforms.
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.lock text eol=lf
.gitignore text eol=lf

# Windows script files stay CRLF for native tooling compatibility.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf